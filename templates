<!DOCTYPE html>
<html lang="hi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Aapka Apna Blood Bank</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@600;700;900&family=Rajdhani:wght@400;500;600;700&family=Nunito:wght@300;400;600&display=swap" rel="stylesheet">
<style>
  :root {
    --red-dark: #7a0000;
    --red-mid: #c0152a;
    --red-bright: #e8213a;
    --red-glow: #ff3355;
    --red-light: #ff6b7a;
    --cream: #fff5f5;
    --dark-bg: #0a0002;
    --card-bg: rgba(255,255,255,0.04);
    --gold: #d4a843;
    --text-light: #ffe0e0;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Rajdhani', sans-serif;
    background: var(--dark-bg);
    color: var(--text-light);
    min-height: 100vh;
    overflow-x: hidden;
    cursor: default;
  }

  /* === ANIMATED BG === */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 20% 20%, rgba(192,21,42,0.18) 0%, transparent 60%),
      radial-gradient(ellipse 60% 80% at 80% 80%, rgba(122,0,0,0.22) 0%, transparent 55%),
      radial-gradient(ellipse 40% 40% at 50% 50%, rgba(232,33,58,0.07) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .particles {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .particle {
    position: absolute;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--red-bright);
    opacity: 0;
    animation: float-particle linear infinite;
  }

  @keyframes float-particle {
    0% { transform: translateY(100vh) scale(0); opacity: 0; }
    10% { opacity: 0.6; }
    90% { opacity: 0.3; }
    100% { transform: translateY(-10vh) scale(1.5); opacity: 0; }
  }

  /* === HEADER === */
  header {
    position: relative;
    z-index: 10;
    text-align: center;
    padding: 3rem 1rem 2rem;
    border-bottom: 1px solid rgba(192,21,42,0.3);
    background: linear-gradient(180deg, rgba(122,0,0,0.3) 0%, transparent 100%);
  }

  .logo-wrap {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .heart-logo {
    width: 64px;
    height: 64px;
    position: relative;
    animation: heartbeat 1.4s ease-in-out infinite;
  }

  @keyframes heartbeat {
    0%, 100% { transform: scale(1); filter: drop-shadow(0 0 8px rgba(232,33,58,0.5)); }
    14% { transform: scale(1.18); filter: drop-shadow(0 0 20px rgba(255,51,85,0.9)); }
    28% { transform: scale(1); }
    42% { transform: scale(1.10); filter: drop-shadow(0 0 14px rgba(232,33,58,0.7)); }
    70% { transform: scale(1); }
  }

  .site-title {
    font-family: 'Cinzel', serif;
    font-size: clamp(1.8rem, 5vw, 3.2rem);
    font-weight: 900;
    background: linear-gradient(135deg, #ff6b7a 0%, #e8213a 40%, #d4a843 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: 0.02em;
    line-height: 1.1;
    text-shadow: none;
  }

  .tagline {
    font-family: 'Nunito', sans-serif;
    font-size: 1rem;
    color: rgba(255,176,176,0.7);
    font-weight: 300;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-top: 0.25rem;
  }

  /* === STATS BAR === */
  .stats-bar {
    display: flex;
    justify-content: center;
    gap: 2rem;
    padding: 1.5rem 1rem;
    position: relative;
    z-index: 5;
    flex-wrap: wrap;
  }

  .stat-item {
    text-align: center;
    padding: 0.75rem 1.5rem;
    background: rgba(192,21,42,0.12);
    border: 1px solid rgba(192,21,42,0.3);
    border-radius: 12px;
    min-width: 120px;
    transition: all 0.3s;
  }

  .stat-item:hover {
    background: rgba(192,21,42,0.2);
    border-color: var(--red-bright);
    transform: translateY(-2px);
  }

  .stat-num {
    font-family: 'Cinzel', serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--red-light);
    display: block;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.75rem;
    color: rgba(255,200,200,0.6);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: 4px;
  }

  /* === MAIN LAYOUT === */
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem 1rem 4rem;
    position: relative;
    z-index: 5;
  }

  /* === TABS === */
  .tabs {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .tab-btn {
    font-family: 'Cinzel', serif;
    font-size: 1rem;
    font-weight: 600;
    padding: 0.85rem 2.2rem;
    border: 2px solid rgba(192,21,42,0.5);
    border-radius: 50px;
    background: transparent;
    color: rgba(255,180,180,0.7);
    cursor: pointer;
    transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
    position: relative;
    overflow: hidden;
    letter-spacing: 0.05em;
  }

  .tab-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--red-mid), var(--red-dark));
    opacity: 0;
    transition: opacity 0.3s;
    border-radius: 50px;
  }

  .tab-btn.active, .tab-btn:hover {
    color: #fff;
    border-color: var(--red-bright);
    transform: scale(1.04);
    box-shadow: 0 4px 20px rgba(232,33,58,0.4), inset 0 1px 0 rgba(255,255,255,0.1);
  }

  .tab-btn.active::before, .tab-btn:hover::before { opacity: 1; }
  .tab-btn span { position: relative; z-index: 1; }

  /* === PANELS === */
  .panel { display: none; }
  .panel.active {
    display: block;
    animation: fadeIn 0.4s ease;
  }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }

  /* === CARD === */
  .card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(192,21,42,0.25);
    border-radius: 20px;
    padding: 2.5rem;
    backdrop-filter: blur(10px);
    box-shadow: 0 8px 40px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.05);
    max-width: 600px;
    margin: 0 auto;
  }

  .card-title {
    font-family: 'Cinzel', serif;
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--red-light);
    text-align: center;
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
  }

  .card-title svg { flex-shrink: 0; }

  /* === FORM === */
  .form-group {
    margin-bottom: 1.5rem;
  }

  label {
    display: block;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255,180,180,0.65);
    margin-bottom: 0.5rem;
    font-weight: 600;
  }

  input, select {
    width: 100%;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(192,21,42,0.35);
    border-radius: 10px;
    padding: 0.85rem 1.1rem;
    color: #fff;
    font-family: 'Rajdhani', sans-serif;
    font-size: 1rem;
    font-weight: 500;
    transition: all 0.25s;
    outline: none;
    -webkit-appearance: none;
  }

  input::placeholder { color: rgba(255,180,180,0.3); }

  input:focus, select:focus {
    border-color: var(--red-bright);
    background: rgba(232,33,58,0.07);
    box-shadow: 0 0 0 3px rgba(232,33,58,0.15);
  }

  select option {
    background: #1a0005;
    color: #fff;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  /* === BUTTON === */
  .btn-main {
    width: 100%;
    padding: 1rem;
    font-family: 'Cinzel', serif;
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: #fff;
    background: linear-gradient(135deg, #c0152a 0%, #8b0000 50%, #c0152a 100%);
    background-size: 200% 100%;
    border: none;
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.35s;
    margin-top: 0.5rem;
    position: relative;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(192,21,42,0.5);
  }

  .btn-main:hover {
    background-position: 100% 0;
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(232,33,58,0.6);
  }

  .btn-main:active { transform: translateY(0) scale(0.98); }

  .btn-main .shine {
    position: absolute;
    top: 0; left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
    animation: shine 2.5s ease-in-out infinite;
  }

  @keyframes shine { 0% { left: -100%; } 60%, 100% { left: 150%; } }

  /* === TOAST === */
  .toast {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%) translateY(100px);
    background: rgba(20,0,4,0.95);
    border: 1px solid var(--red-bright);
    border-radius: 12px;
    padding: 1rem 1.5rem;
    color: #fff;
    font-size: 0.95rem;
    font-weight: 500;
    z-index: 100;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    max-width: 90vw;
    text-align: center;
    box-shadow: 0 4px 30px rgba(0,0,0,0.5);
  }

  .toast.show { transform: translateX(-50%) translateY(0); }
  .toast.success { border-color: #22c55e; }
  .toast.error { border-color: #ef4444; }

  /* === RESULTS === */
  .results-wrap { margin-top: 2rem; }

  .results-header {
    text-align: center;
    font-family: 'Cinzel', serif;
    font-size: 1rem;
    color: rgba(255,180,180,0.6);
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(192,21,42,0.2);
  }

  .results-header strong {
    color: var(--red-light);
    font-size: 1.3rem;
  }

  .donor-card {
    background: rgba(192,21,42,0.08);
    border: 1px solid rgba(192,21,42,0.3);
    border-radius: 14px;
    padding: 1.2rem 1.5rem;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    transition: all 0.25s;
    animation: slideIn 0.3s ease forwards;
  }

  @keyframes slideIn { from { opacity:0; transform: translateX(-15px); } to { opacity:1; transform: translateX(0); } }

  .donor-card:hover {
    background: rgba(192,21,42,0.15);
    border-color: var(--red-bright);
    transform: translateX(4px);
  }

  .donor-info { flex: 1; }

  .donor-name {
    font-family: 'Cinzel', serif;
    font-size: 1.05rem;
    font-weight: 600;
    color: #fff;
    margin-bottom: 4px;
  }

  .donor-meta {
    font-size: 0.85rem;
    color: rgba(255,200,200,0.55);
  }

  .blood-badge {
    font-family: 'Cinzel', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--red-light);
    background: rgba(192,21,42,0.2);
    border: 1px solid rgba(192,21,42,0.4);
    border-radius: 8px;
    padding: 0.4rem 0.8rem;
    min-width: 52px;
    text-align: center;
  }

  .action-btns {
    display: flex;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .action-btn {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1rem;
    border: 1px solid rgba(192,21,42,0.4);
    border-radius: 8px;
    background: transparent;
    color: var(--text-light);
    font-family: 'Rajdhani', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s;
    white-space: nowrap;
  }

  .action-btn:hover {
    background: rgba(192,21,42,0.25);
    border-color: var(--red-bright);
    transform: translateY(-1px);
  }

  .action-btn.whatsapp { border-color: rgba(37,211,102,0.4); color: #25d366; }
  .action-btn.whatsapp:hover { background: rgba(37,211,102,0.1); border-color: #25d366; }
  .action-btn.call { border-color: rgba(232,33,58,0.4); color: var(--red-light); }
  .action-btn.call:hover { background: rgba(232,33,58,0.15); border-color: var(--red-bright); }

  .no-result {
    text-align: center;
    padding: 3rem;
    color: rgba(255,180,180,0.4);
  }

  .no-result .big-icon { font-size: 3rem; margin-bottom: 1rem; opacity: 0.5; }
  .no-result p { font-size: 1rem; }

  /* === DIVIDER === */
  .or-divider {
    text-align: center;
    margin: 2rem 0;
    position: relative;
    color: rgba(255,180,180,0.3);
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .or-divider::before, .or-divider::after {
    content: '';
    position: absolute;
    top: 50%;
    width: calc(50% - 2rem);
    height: 1px;
    background: rgba(192,21,42,0.2);
  }
  .or-divider::before { left: 0; }
  .or-divider::after { right: 0; }

  /* === LOADER === */
  .loader {
    display: inline-block;
    width: 18px; height: 18px;
    border: 2px solid rgba(255,255,255,0.3);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
    vertical-align: middle;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* === RESPONSIVE === */
  @media (max-width: 600px) {
    .card { padding: 1.5rem 1.2rem; }
    .form-row { grid-template-columns: 1fr; }
    .donor-card { flex-direction: column; align-items: flex-start; }
    .action-btns { width: 100%; }
    .action-btn { flex: 1; justify-content: center; }
  }

  /* === RIBBON === */
  .ribbon {
    background: linear-gradient(90deg, transparent, rgba(192,21,42,0.25), rgba(192,21,42,0.35), rgba(192,21,42,0.25), transparent);
    text-align: center;
    padding: 0.6rem;
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,160,160,0.6);
    border-top: 1px solid rgba(192,21,42,0.2);
    border-bottom: 1px solid rgba(192,21,42,0.2);
    margin-bottom: 2.5rem;
    position: relative;
    z-index: 5;
  }

  .pulse-dot {
    display: inline-block;
    width: 6px; height: 6px;
    background: #22c55e;
    border-radius: 50%;
    margin-right: 6px;
    vertical-align: middle;
    animation: pulse-anim 1.5s ease-in-out infinite;
  }
  @keyframes pulse-anim {
    0%, 100% { opacity:1; transform: scale(1); box-shadow: 0 0 0 0 rgba(34,197,94,0.4); }
    50% { opacity:0.8; transform: scale(1.2); box-shadow: 0 0 0 4px rgba(34,197,94,0); }
  }
</style>
</head>
<body>

<div class="particles" id="particles"></div>

<header>
  <div class="logo-wrap">
    <div class="heart-logo">
      <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" width="64" height="64">
        <defs>
          <radialGradient id="hg" cx="50%" cy="40%" r="60%">
            <stop offset="0%" stop-color="#ff6b7a"/>
            <stop offset="50%" stop-color="#e8213a"/>
            <stop offset="100%" stop-color="#7a0000"/>
          </radialGradient>
        </defs>
        <path d="M32 56 C32 56 6 38 6 22 C6 13 13 6 22 6 C26.5 6 30.5 8 32 11 C33.5 8 37.5 6 42 6 C51 6 58 13 58 22 C58 38 32 56 32 56Z" fill="url(#hg)" stroke="rgba(255,100,100,0.3)" stroke-width="0.5"/>
        <path d="M32 23 L34 28 L39 28 L35 31 L37 36 L32 33 L27 36 L29 31 L25 28 L30 28Z" fill="rgba(255,255,255,0.9)"/>
      </svg>
    </div>
    <div>
      <div class="site-title">Aapka Apna Blood Bank</div>
    </div>
  </div>
  <p class="tagline">Khoon do, Zindagi bachao — Ek Kadam Insaniyat Ki Taraf</p>
</header>

<div class="ribbon">
  <span class="pulse-dot"></span>
  Live donors database — Real-time search &nbsp;|&nbsp; 🩸 Ek donation, teen zindagiyaan
</div>

<div class="stats-bar">
  <div class="stat-item">
    <span class="stat-num" id="stat-total">—</span>
    <span class="stat-label">Registered Donors</span>
  </div>
  <div class="stat-item">
    <span class="stat-num" id="stat-cities">—</span>
    <span class="stat-label">Cities Covered</span>
  </div>
  <div class="stat-item">
    <span class="stat-num" id="stat-group">—</span>
    <span class="stat-label">Most Available</span>
  </div>
</div>

<div class="container">
  <div class="tabs">
    <button class="tab-btn active" onclick="switchTab('donor')">
      <span>🩸 Donor Banein</span>
    </button>
    <button class="tab-btn" onclick="switchTab('receiver')">
      <span>🔍 Blood Dhundein</span>
    </button>
  </div>

  <!-- DONOR PANEL -->
  <div class="panel active" id="panel-donor">
    <div class="card">
      <div class="card-title">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path d="M12 21.5C12 21.5 3 15 3 9a9 9 0 0 1 18 0c0 6-9 12.5-9 12.5z" fill="rgba(232,33,58,0.3)" stroke="#e8213a" stroke-width="1.5"/>
          <path d="M12 10 L13 13 L16 13 L13.5 14.8 L14.5 18 L12 16.2 L9.5 18 L10.5 14.8 L8 13 L11 13Z" fill="#ff6b7a"/>
        </svg>
        Donor Registration
      </div>

      <form id="donor-form" onsubmit="registerDonor(event)">
        <div class="form-group">
          <label>Aapka Poora Naam</label>
          <input type="text" id="d-name" placeholder="Jaise: Rahul Sharma" required maxlength="60">
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Mobile Number</label>
            <input type="tel" id="d-mobile" placeholder="10 digit number" maxlength="10" required pattern="[0-9]{10}">
          </div>
          <div class="form-group">
            <label>Aapka Shehar</label>
            <input type="text" id="d-city" placeholder="Jaise: Delhi, Agra" required maxlength="50">
          </div>
        </div>
        <div class="form-group">
          <label>Blood Group</label>
          <select id="d-blood" required>
            <option value="">— Select Blood Group —</option>
            <option>A+</option><option>A-</option>
            <option>B+</option><option>B-</option>
            <option>AB+</option><option>AB-</option>
            <option>O+</option><option>O-</option>
          </select>
        </div>
        <button type="submit" class="btn-main" id="reg-btn">
          <span class="shine"></span>
          <span id="reg-text">🩸 Donor List Mein Add Karein</span>
        </button>
      </form>
    </div>
  </div>

  <!-- RECEIVER PANEL -->
  <div class="panel" id="panel-receiver">
    <div class="card">
      <div class="card-title">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
          <circle cx="11" cy="11" r="7" stroke="#e8213a" stroke-width="1.5"/>
          <path d="M16.5 16.5 L21 21" stroke="#e8213a" stroke-width="1.5" stroke-linecap="round"/>
          <path d="M8 11 H14 M11 8 V14" stroke="#ff6b7a" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        Blood Dhundein
      </div>

      <form id="search-form" onsubmit="searchDonors(event)">
        <div class="form-row">
          <div class="form-group">
            <label>Apna Shehar Likhein</label>
            <input type="text" id="s-city" placeholder="Jaise: Lucknow" required maxlength="50">
          </div>
          <div class="form-group">
            <label>Zaroorat Blood Group</label>
            <select id="s-blood" required>
              <option value="">— Blood Group —</option>
              <option>A+</option><option>A-</option>
              <option>B+</option><option>B-</option>
              <option>AB+</option><option>AB-</option>
              <option>O+</option><option>O-</option>
            </select>
          </div>
        </div>
        <button type="submit" class="btn-main" id="search-btn">
          <span class="shine"></span>
          <span id="search-text">🔍 Donors Dhundein</span>
        </button>
      </form>

      <div class="results-wrap" id="results-wrap" style="display:none"></div>
    </div>
  </div>

</div>

<script>
  // Particles
  const pWrap = document.getElementById('particles');
  for(let i=0;i<25;i++){
    const p=document.createElement('div');
    p.className='particle';
    p.style.left=Math.random()*100+'%';
    p.style.width=p.style.height=(Math.random()*4+2)+'px';
    p.style.animationDuration=(Math.random()*15+8)+'s';
    p.style.animationDelay=(Math.random()*10)+'s';
    p.style.opacity=Math.random()*0.5;
    if(i%4===0){p.style.background='#d4a843';}
    pWrap.appendChild(p);
  }

  // Tab switch
  function switchTab(tab){
    document.querySelectorAll('.tab-btn').forEach((b,i)=>{
      b.classList.toggle('active', (i===0&&tab==='donor')||(i===1&&tab==='receiver'));
    });
    document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
    document.getElementById('panel-'+tab).classList.add('active');
  }

  // Toast
  function showToast(msg, type='success'){
    let t=document.getElementById('toast');
    if(!t){t=document.createElement('div');t.id='toast';t.className='toast';document.body.appendChild(t);}
    t.textContent=msg;
    t.className='toast '+type;
    setTimeout(()=>t.classList.add('show'),10);
    setTimeout(()=>t.classList.remove('show'),3500);
  }

  // Stats
  async function loadStats(){
    try{
      const r=await fetch('/api/stats');
      const d=await r.json();
      document.getElementById('stat-total').textContent=d.total_donors;
      document.getElementById('stat-cities').textContent=d.cities_covered;
      document.getElementById('stat-group').textContent=d.most_common;
    }catch(e){}
  }
  loadStats();

  // Register
  async function registerDonor(e){
    e.preventDefault();
    const btn=document.getElementById('reg-btn');
    const txt=document.getElementById('reg-text');
    btn.disabled=true;
    txt.innerHTML='<span class="loader"></span> Saving...';
    try{
      const r=await fetch('/api/register',{
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({
          name:document.getElementById('d-name').value,
          mobile:document.getElementById('d-mobile').value,
          city:document.getElementById('d-city').value,
          blood_group:document.getElementById('d-blood').value
        })
      });
      const d=await r.json();
      if(d.success){
        showToast(d.message,'success');
        document.getElementById('donor-form').reset();
        loadStats();
      } else {
        showToast(d.message,'error');
      }
    }catch(err){
      showToast('Network error. Dobara try karein.','error');
    }
    btn.disabled=false;
    txt.innerHTML='🩸 Donor List Mein Add Karein';
  }

  // Search
  async function searchDonors(e){
    e.preventDefault();
    const btn=document.getElementById('search-btn');
    const txt=document.getElementById('search-text');
    const wrap=document.getElementById('results-wrap');
    btn.disabled=true;
    txt.innerHTML='<span class="loader"></span> Dhoondh raha hoon...';
    wrap.style.display='none';
    try{
      const r=await fetch('/api/search',{
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({
          city:document.getElementById('s-city').value,
          blood_group:document.getElementById('s-blood').value
        })
      });
      const d=await r.json();
      if(d.success){
        renderResults(d.donors, d.count,
          document.getElementById('s-city').value,
          document.getElementById('s-blood').value);
      } else {
        showToast(d.message,'error');
      }
    }catch(err){
      showToast('Network error.','error');
    }
    btn.disabled=false;
    txt.innerHTML='🔍 Donors Dhundein';
  }

  function renderResults(donors, count, city, bg){
    const wrap=document.getElementById('results-wrap');
    wrap.style.display='block';
    if(count===0){
      wrap.innerHTML=`
        <div class="no-result">
          <div class="big-icon">🩸</div>
          <p><strong style="color:rgba(255,180,180,0.7)">${bg}</strong> blood ${city.charAt(0).toUpperCase()+city.slice(1)} mein abhi available nahi hai.</p>
          <p style="margin-top:0.75rem; font-size:0.85rem; opacity:0.6">Aap khud donor bankar logo ki madad kar sakte hain!</p>
        </div>`;
      return;
    }
    let html=`<div class="results-header">
      <strong>${count}</strong> donor${count>1?'s':''} mila ${city.charAt(0).toUpperCase()+city.slice(1)} mein — <strong>${bg}</strong>
    </div>`;
    donors.forEach((d,i)=>{
      html+=`
      <div class="donor-card" style="animation-delay:${i*0.07}s">
        <div class="donor-info">
          <div class="donor-name">${escHtml(d.name)}</div>
          <div class="donor-meta">📍 ${escHtml(d.city)}</div>
        </div>
        <div class="blood-badge">${escHtml(d.blood_group)}</div>
        <div class="action-btns">
          <a href="tel:${escHtml(d.mobile)}" class="action-btn call">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.06 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 16z"/></svg>
            Call
          </a>
          <a href="https://wa.me/91${escHtml(d.mobile)}?text=Namaste%20${encodeURIComponent(d.name)}%20ji%2C%20mujhe%20${encodeURIComponent(d.blood_group)}%20blood%20ki%20zaroorat%20hai.%20Kya%20aap%20madad%20kar%20sakte%20hain%3F" target="_blank" class="action-btn whatsapp">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.115.554 4.099 1.523 5.819L.057 23.93l6.284-1.449C8.018 23.48 9.962 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.89 0-3.663-.523-5.176-1.432l-.37-.22-3.733.86.936-3.619-.241-.375C2.523 15.641 2 13.876 2 12 2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
            WhatsApp
          </a>
        </div>
      </div>`;
    });
    wrap.innerHTML=html;
  }

  function escHtml(s){
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
</script>
</body>
</html>
